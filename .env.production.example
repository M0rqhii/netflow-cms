# Production / staging template.
# Current staging stack: Render (API) + Vercel (Admin) + Supabase (DB) + Upstash (Redis) + Resend (Email)
#
# For Render: set these as Environment Variables in the Render dashboard.
# For Vercel: set NEXT_PUBLIC_* vars in the Vercel dashboard.

NODE_ENV=production
APP_PROFILE=production

# Database (Supabase)
# Pooler (Transaction mode) — used by the app at runtime
DATABASE_URL=postgresql://postgres.XXXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?schema=public
# Direct connection — used by Prisma migrations only
DIRECT_URL=postgresql://postgres.XXXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?schema=public

# Redis (Upstash)
REDIS_URL=rediss://default:XXXXX@eu1-XXXXX.upstash.io:6379
REDIS_DISABLED=0

# API (Render)
PORT=4000
API_PREFIX=/api/v1
API_BASE_URL=https://netflow-cms.onrender.com
UPLOAD_DIR=/data/uploads

# Frontend / CORS (Vercel)
FRONTEND_URL=https://netflow-cms-admin.vercel.app
CORS_ORIGIN=https://netflow-cms-admin.vercel.app
NEXT_PUBLIC_API_URL=https://netflow-cms.onrender.com/api/v1
NEXT_PUBLIC_APP_PROFILE=production

# Security
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_SUPER_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET=CHANGE_ME_DIFFERENT_SECRET_MIN_32_CHARS
REFRESH_TOKEN_EXPIRES_IN=604800

# Mail / Notifications (Resend)
MAIL_PROVIDER=resend
RESEND_API_KEY=re_XXXXX
MAIL_FROM_EMAIL="Net-Flow <no-reply@net-flow.pl>"
MAIL_REPLY_TO="support@net-flow.pl"
MAIL_SUPPORT_EMAIL="support@net-flow.pl"
MAIL_BRAND_NAME="Net-Flow"
MAIL_BRAND_LOGO_URL="https://netflow-cms-admin.vercel.app/assets/Net-Flow-Logo-Horizontal.png"
