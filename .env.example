# Copy to .env and adjust values for local development

# Database Configuration
DATABASE_URL=postgresql://netflow:netflow_dev_password@localhost:5432/netflow_cms?schema=public

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# API Configuration
PORT=4000
NODE_ENV=development
API_PREFIX=/api/v1

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Mail / Notifications
MAIL_PROVIDER=resend
RESEND_API_KEY=CHANGE_ME
MAIL_FROM_EMAIL="Net-Flow <no-reply@net-flow.pl>"
MAIL_REPLY_TO="support@net-flow.pl"
MAIL_SUPPORT_EMAIL="support@net-flow.pl"
MAIL_BRAND_NAME="Net-Flow"
MAIL_BRAND_LOGO_URL="http://localhost:3000/assets/Net-Flow-Logo-Horizontal.png"

# Security
# IMPORTANT: Generate strong random secrets for production!
# You can use: openssl rand -base64 32
JWT_SECRET=change-me-to-random-secret-min-32-chars
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=change-me-to-different-random-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Application
APP_NAME=Net-Flow
APP_VERSION=1.0.0
