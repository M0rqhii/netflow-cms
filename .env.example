# Copy to .env and adjust values for local development

# Database Configuration
DATABASE_URL=postgresql://netflow:netflow_dev_password@localhost:5432/netflow_cms?schema=public

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# API Configuration
PORT=4000
NODE_ENV=development
API_PREFIX=/api/v1

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Mail / Notifications
MAIL_PROVIDER=resend
RESEND_API_KEY=CHANGE_ME
MAIL_FROM_EMAIL="Net-Flow <no-reply@net-flow.pl>"
MAIL_REPLY_TO="support@net-flow.pl"
MAIL_SUPPORT_EMAIL="support@net-flow.pl"
MAIL_BRAND_NAME="Net-Flow"
MAIL_BRAND_LOGO_URL="http://localhost:3000/assets/Net-Flow-Logo-Horizontal.png"

# Security
# IMPORTANT: Generate strong random secrets! NEVER use default values in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Or: openssl rand -base64 48
JWT_SECRET=GENERATE_ME_REQUIRED_run_openssl_rand_base64_48
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET=GENERATE_ME_REQUIRED_must_differ_from_jwt_secret
REFRESH_TOKEN_EXPIRES_IN=604800

# Dev Module (set to 'true' to enable /dev endpoints — never in production)
ENABLE_DEV_MODE=true

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Application
APP_NAME=Net-Flow
APP_VERSION=1.0.0
