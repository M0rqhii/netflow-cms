# Database Configuration
DATABASE_URL="postgresql://netflow:netflow_dev_password@localhost:5432/netflow_cms?schema=public"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Server Configuration
PORT=4000
NODE_ENV=development

# API Configuration
API_PREFIX="/api/v1"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Security (REQUIRED - app will not start without these)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="GENERATE_ME_REQUIRED"
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET="GENERATE_ME_REQUIRED_must_differ_from_jwt_secret"
REFRESH_TOKEN_EXPIRES_IN=604800

# Mail / Notifications
MAIL_PROVIDER="resend"
RESEND_API_KEY=""
MAIL_FROM_EMAIL="Net-Flow <no-reply@net-flow.pl>"
MAIL_REPLY_TO="support@net-flow.pl"
MAIL_SUPPORT_EMAIL="support@net-flow.pl"
MAIL_BRAND_NAME="Net-Flow"
MAIL_BRAND_LOGO_URL="http://localhost:3000/assets/Net-Flow-Logo-Horizontal.png"
