# Standalone API template.
# Use only when running apps/api directly (not via root turbo).
# Copy to .env and fill in values.

NODE_ENV=development
APP_PROFILE=development

# Database (local docker-compose)
DATABASE_URL=postgresql://netflow:netflow_dev_password@localhost:5432/netflow_cms?schema=public
DIRECT_URL=postgresql://netflow:netflow_dev_password@localhost:5432/netflow_cms?schema=public

# Redis (local docker-compose)
REDIS_URL=redis://localhost:6379
REDIS_DISABLED=0

# API
PORT=4000
API_PREFIX=/api/v1
API_BASE_URL=http://localhost:4000
UPLOAD_DIR=uploads

# Frontend / CORS
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Security
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET=dev-refresh-token-secret-change-me
REFRESH_TOKEN_EXPIRES_IN=604800

# Mail / Notifications (dev = logs to console)
MAIL_PROVIDER=dev
RESEND_API_KEY=
MAIL_FROM_EMAIL="Net-Flow <no-reply@net-flow.pl>"
MAIL_REPLY_TO="support@net-flow.pl"
MAIL_SUPPORT_EMAIL="support@net-flow.pl"
MAIL_BRAND_NAME="Net-Flow"
MAIL_BRAND_LOGO_URL="http://localhost:3000/assets/Net-Flow-Logo-Horizontal.png"
